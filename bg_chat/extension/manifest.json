{
  "manifest_version": 2,
  "name": "BG Chat Panel",
  "version": "1.0",
  "description": "Chat panel for the bg-chat web agent",
  "permissions": [],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_title": "Open BG Chat",
    "default_popup": "sidepanel.html"
  },
  "content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self'"
}
